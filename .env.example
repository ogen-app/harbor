# Harbor configuration. Copy to .env and adjust; every key + default is defined
# in src/config/config.go.

# Listen address for the combined API + embedded UI (Ogen owns :9001).
ADDR=:9002

# Postgres DSN.
DATABASE_DSN=postgres://harbor:harbor@localhost:5432/harbor?sslmode=disable

# Local ergonomics: DEBUG=true enables verbose bun query logging and defaults
# the log format to human-readable text.
DEBUG=true

# Structured logging. LOG_LEVEL: debug|info|warn|error. LOG_FORMAT: json|text
# (empty ⇒ text when DEBUG=true, JSON otherwise).
LOG_LEVEL=info
LOG_FORMAT=

# Connection-pool sizing.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Set ONLY if the UI is served from a separate origin. The default single-binary
# and `next dev` (proxied) setups are same-origin, so leave this empty.
CORS_ALLOWED_ORIGINS=
